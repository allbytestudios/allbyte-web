---
interface Props {
  theme?: "engine" | "heart";
}

const { theme = "engine" } = Astro.props;
---

<footer class:list={["site-footer", `site-footer--${theme}`]}>
  <a href="mailto:allbytestudios@gmail.com" class="footer-contact">allbytestudios@gmail.com</a>
  <span class="footer-copyright">&copy; 2026 AllByte Studios</span>
</footer>

<style>
  .site-footer {
    text-align: center;
    padding: 1.5rem 1rem;
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
  }

  .site-footer--engine {
    background: #1e2a3a;
    color: rgba(224, 231, 255, 0.4);
  }

  .site-footer--heart {
    background: #cec08a;
    color: #5a4d38;
  }

  .footer-contact {
    font-size: 0.85rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .site-footer--engine .footer-contact {
    color: rgba(167, 243, 208, 0.5);
  }

  .site-footer--engine .footer-contact:hover {
    color: rgba(167, 243, 208, 0.8);
  }

  .site-footer--heart .footer-contact {
    color: #5a4d38;
  }

  .site-footer--heart .footer-contact:hover {
    color: #2a2218;
  }

  .footer-copyright {
    font-size: 0.8rem;
  }
</style>
