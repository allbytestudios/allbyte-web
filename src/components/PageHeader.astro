---
/**
 * Standardized sticky page header with breadcrumbs (desktop) and back button (mobile).
 *
 * Props:
 *   theme: "engine" | "heart" — color scheme matching the page
 *   title: page title (visible as h1)
 *   backHref: URL for the back/up navigation
 *   backLabel: label for the back button (mobile) and last breadcrumb segment
 *   breadcrumbs?: array of {href, label} for desktop trail (newest = current page, omit current)
 *
 * Mobile (<768px): single back button, 44x44 minimum touch target, title centered.
 * Desktop (>=768px): breadcrumbs left-aligned (if provided), title centered, falls back to back button.
 */
interface Crumb {
  href: string;
  label: string;
}

interface Props {
  theme?: "engine" | "heart";
  title: string;
  backHref: string;
  backLabel?: string;
  breadcrumbs?: Crumb[];
  /** When true, hide the title on desktop (use when title duplicates the last breadcrumb). */
  hideTitleOnDesktop?: boolean;
}

const {
  theme = "engine",
  title,
  backHref,
  backLabel = "Back",
  breadcrumbs = [],
  hideTitleOnDesktop = false,
} = Astro.props;
---

<header class={`page-header page-header-${theme}`}>
  <!-- Desktop: stacked rows (nav, title, slot). Mobile: single row with back+title side-by-side. -->
  <div class="header-row-mobile">
    <a href={backHref} class="back-link-mobile" aria-label={`Back to ${backLabel}`}>&larr;</a>
    <h1 class="page-title page-title-mobile">{title}</h1>
    <div class="header-spacer-mobile" aria-hidden="true"></div>
  </div>
  <div class="header-nav-desktop">
    {breadcrumbs.length > 0 ? (
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          {breadcrumbs.map((crumb, i) => (
            <li>
              <a href={crumb.href}>
                {crumb.label === "Home" && <span class="home-icon" aria-hidden="true">⌂ </span>}{crumb.label}
              </a>
              {i < breadcrumbs.length - 1 && <span class="separator" aria-hidden="true">/</span>}
            </li>
          ))}
        </ol>
      </nav>
    ) : (
      <a href={backHref} class="back-link-desktop">&larr; {backLabel}</a>
    )}
  </div>
  {!hideTitleOnDesktop && (
    <h1 class="page-title page-title-desktop">{title}</h1>
  )}
  <div class="header-slot">
    <slot />
  </div>
</header>

<style>
  .page-header {
    text-align: center;
    padding: 0.5rem 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .page-header-engine {
    background: #1a1e26;
  }

  .page-header-heart {
    background: var(--heart-bg-secondary, #c5b67e);
  }

  /* === Desktop: stacked layout === */
  .header-row-mobile {
    display: none;
  }

  .header-nav-desktop {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: flex-start;
  }

  .page-title-desktop {
    text-align: center;
    margin-top: 0.1rem;
  }

  /* Breadcrumbs (desktop) */
  .breadcrumbs {
    flex: 0 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .home-icon {
    font-size: 1.1em;
    line-height: 0;
    vertical-align: -0.05em;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: "Courier New", monospace;
    font-size: 1rem;
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .page-header-engine .breadcrumbs a {
    color: var(--engine-accent, #a7f3d0);
  }

  .page-header-heart .breadcrumbs a {
    color: var(--heart-accent, #3a3020);
  }

  .breadcrumbs a {
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .page-header-engine .breadcrumbs a {
    background: rgba(167, 243, 208, 0.06);
    border: 1px solid rgba(167, 243, 208, 0.18);
  }

  .page-header-engine .breadcrumbs a:hover {
    background: rgba(167, 243, 208, 0.18);
    border-color: rgba(167, 243, 208, 0.4);
  }

  .page-header-heart .breadcrumbs a {
    background: rgba(58, 48, 32, 0.06);
    border: 1px solid rgba(58, 48, 32, 0.2);
  }

  .page-header-heart .breadcrumbs a:hover {
    background: rgba(58, 48, 32, 0.15);
    border-color: rgba(58, 48, 32, 0.4);
  }

  .separator {
    opacity: 0.7;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0.15rem;
  }

  .page-header-engine .separator {
    color: rgba(167, 243, 208, 0.6);
  }

  .page-header-heart .separator {
    color: rgba(58, 48, 32, 0.6);
  }

  /* Desktop back link (used when no breadcrumbs given) */
  .back-link-desktop {
    flex: 0 0 auto;
    text-decoration: none;
    font-family: "Courier New", monospace;
    font-size: 1rem;
    padding: 0.5rem 0.85rem;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    transition: background 0.15s, border-color 0.15s;
  }

  .page-header-engine .back-link-desktop {
    color: #a7f3d0;
    background: rgba(167, 243, 208, 0.08);
    border: 1px solid rgba(167, 243, 208, 0.25);
  }

  .page-header-engine .back-link-desktop:hover {
    background: rgba(167, 243, 208, 0.18);
    border-color: rgba(167, 243, 208, 0.5);
  }

  .page-header-heart .back-link-desktop {
    color: var(--heart-accent, #3a3020);
    background: rgba(58, 48, 32, 0.08);
    border: 1px solid rgba(58, 48, 32, 0.3);
  }

  .page-header-heart .back-link-desktop:hover {
    background: rgba(58, 48, 32, 0.15);
    border-color: rgba(58, 48, 32, 0.55);
  }

  /* Mobile back link (icon only) — visibility controlled by parent .header-row-mobile */
  .back-link-mobile {
    flex: 0 0 auto;
    text-decoration: none;
    font-family: "Courier New", monospace;
    font-size: 1.4rem;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: background 0.15s, border-color 0.15s;
  }

  .page-header-engine .back-link-mobile {
    color: #a7f3d0;
    background: rgba(167, 243, 208, 0.08);
    border: 1px solid rgba(167, 243, 208, 0.25);
  }

  .page-header-heart .back-link-mobile {
    color: var(--heart-accent, #3a3020);
    background: rgba(58, 48, 32, 0.08);
    border: 1px solid rgba(58, 48, 32, 0.3);
  }

  /* Title */
  .page-title {
    flex: 1 1 auto;
    margin: 0;
    font-family: "Courier New", monospace;
    font-size: 1.6rem;
    font-weight: 700;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  /* When breadcrumbs are present, hide the redundant title on desktop
     (breadcrumbs already show context). Title still appears on mobile
     where breadcrumbs are hidden. */
  .page-title-mobile-only {
    display: none;
  }

  .page-header-engine .page-title {
    color: #a7f3d0;
  }

  .page-header-heart .page-title {
    color: var(--heart-accent, #3a3020);
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
  }

  /* Spacer to balance the back button on the left and keep title centered */
  .header-spacer {
    flex: 0 0 auto;
    min-width: 44px;
  }

  .header-spacer-mobile {
    flex: 0 0 auto;
    width: 44px;
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .header-nav-desktop,
    .page-title-desktop {
      display: none;
    }

    .header-row-mobile {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      min-height: 44px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .page-title {
      font-size: 1.2rem;
    }
  }

  /* On desktop, hide the mobile-only title rendering */
  @media (min-width: 769px) {
    .page-title-mobile {
      display: none;
    }
  }
</style>
