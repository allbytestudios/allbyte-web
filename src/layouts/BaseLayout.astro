---
import { ClientRouter } from "astro:transitions";
import MusicPlayer from "../components/MusicPlayer.svelte";
import AuthInit from "../components/AuthInit.svelte";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AllByte Studios",
  description = "Indie game studio — where engineering meets artistry.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <AuthInit client:load />
    <slot />
    <div transition:persist="music-player">
      <MusicPlayer client:load />
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
