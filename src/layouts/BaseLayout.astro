---
import { ClientRouter } from "astro:transitions";
import MusicPlayer from "../components/MusicPlayer.svelte";
import AuthInit from "../components/AuthInit.svelte";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AllByte Studios",
  description = "Indie game studio — where engineering meets artistry.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <AuthInit client:load />
    <slot />
    <div transition:persist="music-player">
      <MusicPlayer client:load />
    </div>
    <script>
      // Set body.is-admin once auth resolves, so CSS rules gated on that
      // class (draft devlog posts, etc.) can reveal admin-only content.
      // Re-runs on every client-side navigation via ClientRouter.
      function checkAdmin() {
        const token = localStorage.getItem("allbyte_token");
        document.body.classList.remove("is-admin");
        if (!token) return;
        fetch("https://wj3xkrm1r1.execute-api.us-east-1.amazonaws.com/auth/me", {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            if (d?.user?.tier === "admin") {
              document.body.classList.add("is-admin");
            }
          })
          .catch(() => {});
      }
      checkAdmin();
      document.addEventListener("astro:page-load", checkAdmin);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
