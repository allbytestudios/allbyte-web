---
import { ClientRouter } from "astro:transitions";
import MusicPlayer from "../components/MusicPlayer.svelte";
import AuthInit from "../components/AuthInit.svelte";
import DevAuthSwitcher from "../components/DevAuthSwitcher.svelte";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AllByte Studios",
  description = "Indie game studio — where engineering meets artistry.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <AuthInit client:load />
    <DevAuthSwitcher client:load />
    <slot />
    <div transition:persist="music-player">
      <MusicPlayer client:load />
    </div>
    <script>
      // Set body.is-hero-plus / body.is-admin once auth resolves, so CSS
      // rules gated on those classes (draft devlog previews, deep test
      // inspection, etc.) can reveal tier-gated content without a server
      // round-trip per element. Re-runs on every client-side navigation.
      function syncTierClasses() {
        const token = localStorage.getItem("allbyte_token");
        document.body.classList.remove("is-admin", "is-hero-plus");
        if (!token) return;
        fetch("https://wj3xkrm1r1.execute-api.us-east-1.amazonaws.com/auth/me", {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            const tier = d?.user?.tier;
            if (tier === "hero" || tier === "legend" || tier === "admin") {
              document.body.classList.add("is-hero-plus");
            }
            if (tier === "admin") {
              document.body.classList.add("is-admin");
            }
          })
          .catch(() => {});
      }
      syncTierClasses();
      document.addEventListener("astro:page-load", syncTierClasses);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
