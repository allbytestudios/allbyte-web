---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Footer from "../../components/Footer.astro";
import AdminUsersApp from "../../components/AdminUsersApp.svelte";
---

<BaseLayout
  title="User Admin — AllByte Studios"
  description="Admin-only user management page."
>
  <PageHeader
    theme="engine"
    title="Admin / Users"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[
      { href: "/", label: "Home" },
      { href: "/admin/users/", label: "Admin" },
    ]}
  />
  <main class="admin-shell">
    <AdminUsersApp client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .admin-shell {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
    padding: 0.5rem 0 2rem;
  }
</style>
