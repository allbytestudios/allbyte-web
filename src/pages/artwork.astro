---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import spriteGifs from "../data/sprite-gifs.json";
import manifest from "../../scripts/asset-manifest.json";

const title = "Artwork — AllByte Studios";
const description = "Hand-crafted sprites, animations, and backgrounds from The Chronicles of Nesis.";

// Group sprites by character
const byCharacter: Record<string, { animation: string; file: string }[]> = {};
for (const sprite of spriteGifs) {
  if (!byCharacter[sprite.character]) byCharacter[sprite.character] = [];
  byCharacter[sprite.character].push({ animation: sprite.animation, file: sprite.file });
}

// Get category info from manifest
const characterMeta: Record<string, { category: string; hidden?: boolean }> = {};
for (const [name, config] of Object.entries(manifest.spriteGifs)) {
  characterMeta[name] = { category: (config as any).category, hidden: (config as any).hidden };
}

const allies = Object.entries(byCharacter).filter(([name]) => characterMeta[name]?.category === "ally" && !characterMeta[name]?.hidden);
const enemies = Object.entries(byCharacter).filter(([name]) => characterMeta[name]?.category === "enemy" && !characterMeta[name]?.hidden);
const bosses = Object.entries(byCharacter).filter(([name]) => characterMeta[name]?.category === "boss" && !characterMeta[name]?.hidden);

// Hidden characters — show as mystery placeholders
const hiddenAllies = Object.entries(characterMeta).filter(([, m]) => m.category === "ally" && m.hidden);
const hiddenBosses = Object.entries(characterMeta).filter(([, m]) => m.category === "boss" && m.hidden);

// Locked animations per character (abilities not yet shown)
const lockedAnimations: Record<string, string[]> = {
  "Elias": ["Smite Line", "Smite Line (alt)"],
};

// Characters gated behind subscription tiers. Server-side tagged on the
// character card; client-side script unlocks after auth check passes.
const GATED_CHARACTERS: Record<string, "initiate" | "hero" | "legend"> = {
  // Names match the lowercase keys in sprite-gifs.json (the asset-manifest
  // uses the directory casing, which is mostly lowercase except Falmri).
  eastwood: "initiate",
  Falmri: "hero",
  spiting: "hero",
  spiter: "hero",
  vepir: "hero",
};

// Per-character animations gated behind a tier. Keyed by character name,
// then a set of animation names (raw, not display-formatted).
const GATED_ANIMATIONS: Record<string, Record<string, "initiate" | "hero" | "legend">> = {
  Elias: {
    SweepAttackDownRight: "initiate",
    SweepAttackUpLeft: "initiate",
    Casting: "initiate",
  },
};

function gateInfoFor(name: string): { gated: boolean; tier: string; label: string } {
  const tier = GATED_CHARACTERS[name];
  if (!tier) return { gated: false, tier: "", label: "" };
  const label = tier[0].toUpperCase() + tier.slice(1) + "+";
  return { gated: true, tier, label };
}

function animationGateFor(character: string, animation: string): {
  gated: boolean;
  tier: string;
  label: string;
} {
  const tier = GATED_ANIMATIONS[character]?.[animation];
  if (!tier) return { gated: false, tier: "", label: "" };
  const label = tier[0].toUpperCase() + tier.slice(1) + "+";
  return { gated: true, tier, label };
}
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <header class="page-header">
      <img src="/Flourish.png" alt="" class="flourish flourish-left" />
      <img src="/Flourish.png" alt="" class="flourish flourish-right" />
      <a href="/" class="back-link">&larr; Back</a>
      <div class="header-text">
        <h1 class="page-title">Artwork</h1>
        <p class="page-sub">Hand-crafted sprites, animations, and backgrounds</p>
      </div>
      <div class="header-spacer" aria-hidden="true"></div>
    </header>

    <main class="content">
      <!-- Allies -->
      <section class="category-section">
        <h2 class="category-title">Allies</h2>
        <div class="characters">
          {allies.map(([name, sprites]) => {
            const charGate = gateInfoFor(name);
            return (
              <div
                class={`character-card${charGate.gated ? " gated" : ""}`}
                data-gated={charGate.gated ? "true" : "false"}
                data-required-tier={charGate.tier}
              >
                {charGate.gated && (
                  <Fragment>
                    <div class="sprite-showcase gated-placeholder">
                      <div class="mystery-sprite">?</div>
                    </div>
                    <p class="mystery-text">&#128274; Unlock with {charGate.label}</p>
                  </Fragment>
                )}
                <h3 class="character-name">
                  {name}
                  {charGate.gated && <span class="gate-badge">&#128274; {charGate.label}</span>}
                </h3>
                <div class={`sprite-showcase${charGate.gated ? " real-content" : ""}`}>
                  <img src={sprites.find(s => s.animation === "IdleDown")?.file || sprites[0].file} alt={`${name} idle`} class="sprite-hero" />
                </div>
                <div class={`sprite-grid${charGate.gated ? " real-content" : ""}`}>
                  {sprites.map(s => {
                    const animGate = animationGateFor(name, s.animation);
                    return (
                      <div
                        class={`sprite-cell${animGate.gated ? " gated-cell" : ""}`}
                        data-gated={animGate.gated ? "true" : "false"}
                        data-required-tier={animGate.tier}
                      >
                        {animGate.gated && (
                          <div class="cell-locked-placeholder">
                            <div class="locked-sprite-small">&#128274;</div>
                            <span class="sprite-label">{s.animation.replace(/([A-Z])/g, " $1").trim()}</span>
                            <span class="cell-gate-badge">&#128274; {animGate.label}</span>
                          </div>
                        )}
                        <img src={s.file} alt={`${name} ${s.animation}`} class={`sprite-gif${animGate.gated ? " real-cell-content" : ""}`} loading="lazy" />
                        <span class={`sprite-label${animGate.gated ? " real-cell-content" : ""}`}>{s.animation.replace(/([A-Z])/g, " $1").trim()}</span>
                      </div>
                    );
                  })}
                  {(lockedAnimations[name] || []).map(label => (
                    <div class="sprite-cell locked-cell">
                      <div class="locked-sprite-small">&#128274;</div>
                      <span class="sprite-label">{label}</span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}

          {hiddenAllies.map(([name]) => (
            <div class="character-card mystery-card">
              <h3 class="character-name">???</h3>
              <div class="sprite-showcase">
                <div class="mystery-sprite">?</div>
              </div>
              <p class="mystery-text">This ally hasn't been revealed yet.</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Enemies -->
      <section class="category-section">
        <h2 class="category-title">Enemies</h2>
        <div class="characters characters-masonry">
          {enemies.map(([name, sprites]) => {
            const charGate = gateInfoFor(name);
            return (
              <div
                class={`character-card${charGate.gated ? " gated" : ""}`}
                data-gated={charGate.gated ? "true" : "false"}
                data-required-tier={charGate.tier}
              >
                {charGate.gated && (
                  <Fragment>
                    <div class="sprite-showcase gated-placeholder">
                      <div class="mystery-sprite">?</div>
                    </div>
                    <p class="mystery-text">&#128274; Unlock with {charGate.label}</p>
                  </Fragment>
                )}
                <h3 class="character-name">
                  {name}
                  {charGate.gated && <span class="gate-badge">&#128274; {charGate.label}</span>}
                </h3>
                <div class={`sprite-showcase${charGate.gated ? " real-content" : ""}`}>
                  <img src={sprites.find(s => s.animation === "IdleDown")?.file || sprites[0].file} alt={`${name} idle`} class="sprite-hero" />
                </div>
                <div class={`sprite-grid${charGate.gated ? " real-content" : ""}`}>
                  {sprites.map(s => (
                    <div class="sprite-cell">
                      <img src={s.file} alt={`${name} ${s.animation}`} class="sprite-gif" loading="lazy" />
                      <span class="sprite-label">{s.animation.replace(/([A-Z])/g, " $1").trim()}</span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}

          <!-- Locked enemy placeholder -->
          <div class="character-card locked-card">
            <h3 class="character-name">???</h3>
            <div class="sprite-showcase">
              <div class="locked-sprite">&#128274;</div>
            </div>
            <p class="locked-text">More enemies coming soon.</p>
          </div>
        </div>
      </section>

      <!-- Bosses -->
      <section class="category-section">
        <h2 class="category-title">Bosses</h2>
        <div class="characters">
          {bosses.map(([name, sprites]) => {
            const charGate = gateInfoFor(name);
            return (
              <div
                class={`character-card${charGate.gated ? " gated" : ""}`}
                data-gated={charGate.gated ? "true" : "false"}
                data-required-tier={charGate.tier}
              >
                {charGate.gated && (
                  <Fragment>
                    <div class="sprite-showcase gated-placeholder">
                      <div class="mystery-sprite">?</div>
                    </div>
                    <p class="mystery-text">&#128274; Unlock with {charGate.label}</p>
                  </Fragment>
                )}
                <h3 class="character-name">
                  {name}
                  {charGate.gated && <span class="gate-badge">&#128274; {charGate.label}</span>}
                </h3>
                <div class={`sprite-showcase${charGate.gated ? " real-content" : ""}`}>
                  <img src={sprites.find(s => s.animation === "IdleDown")?.file || sprites[0].file} alt={`${name} idle`} class="sprite-hero" />
                </div>
                <div class={`sprite-grid${charGate.gated ? " real-content" : ""}`}>
                  {sprites.map(s => (
                    <div class="sprite-cell">
                      <img src={s.file} alt={`${name} ${s.animation}`} class="sprite-gif" loading="lazy" />
                      <span class="sprite-label">{s.animation.replace(/([A-Z])/g, " $1").trim()}</span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}

          <!-- Locked boss placeholder -->
          <div class="character-card locked-card">
            <h3 class="character-name">???</h3>
            <div class="sprite-showcase">
              <div class="locked-sprite">&#128274;</div>
            </div>
            <p class="locked-text">More bosses to discover.</p>
          </div>
        </div>
      </section>

      <!-- Backgrounds -->
      <section class="category-section">
        <h2 class="category-title">Backgrounds</h2>
        <p class="section-note">Screenshots of fully composed scenes — coming soon.</p>
        <div class="bg-grid">
          <div class="bg-card locked-card">
            <div class="locked-bg">&#128274;</div>
            <span class="bg-label">Laria — Main Square</span>
          </div>
          <div class="bg-card locked-card">
            <div class="locked-bg">&#128274;</div>
            <span class="bg-label">Dwarven Ruins</span>
          </div>
          <div class="bg-card locked-card">
            <div class="locked-bg">&#128274;</div>
            <span class="bg-label">More locations to discover</span>
          </div>
        </div>
      </section>

      <!-- Typography -->
      <section class="category-section">
        <h2 class="category-title">Typography</h2>
        <p class="section-note">
          ModernGoth — a custom typeface handcrafted for The Chronicles of Nesis.
          <a href="/fonts/" class="font-link">View the full specimen →</a>
        </p>
      </section>
    </main>

    <Footer theme="heart" />
  </div>
  <script>
    const API = "https://wj3xkrm1r1.execute-api.us-east-1.amazonaws.com";
    const TIER_RANK: Record<string, number> = {
      default: 0,
      initiate: 1,
      hero: 2,
      legend: 3,
      admin: 4,
    };
    function tierAtLeast(userTier: string | null | undefined, required: string): boolean {
      const u = TIER_RANK[(userTier ?? "default") as string] ?? 0;
      const r = TIER_RANK[required] ?? 0;
      return u >= r;
    }

    async function checkTierAndUnlock() {
      const token = localStorage.getItem("allbyte_token");
      if (!token) return;
      try {
        const res = await fetch(`${API}/auth/me`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) return;
        const data = await res.json();
        const tier = data?.user?.tier ?? "default";

        // Unlock character-level gates
        document.querySelectorAll<HTMLElement>('.character-card.gated').forEach(card => {
          const required = card.dataset.requiredTier || "initiate";
          if (tierAtLeast(tier, required)) {
            card.classList.remove("gated");
            card.querySelector(".gate-badge")?.remove();
          }
        });

        // Unlock per-cell animation gates
        document.querySelectorAll<HTMLElement>('.sprite-cell.gated-cell').forEach(cell => {
          const required = cell.dataset.requiredTier || "initiate";
          if (tierAtLeast(tier, required)) {
            cell.classList.remove("gated-cell");
            cell.querySelector(".cell-gate-badge")?.remove();
          }
        });
      } catch {
        // Network error — fail closed (stay locked)
      }
    }

    checkTierAndUnlock();
  </script>
</BaseLayout>

<style is:global>
  .page {
    min-height: 100dvh;
    background: #ddd5b8;
    display: flex;
    flex-direction: column;
  }

  .page-header {
    background: #cec08a;
    padding: 0.4rem 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    overflow: clip;
    min-height: 56px;
  }

  .header-spacer {
    flex: 0 0 auto;
    width: 44px;
  }

  .flourish {
    position: absolute;
    top: 0;
    height: 100%;
    width: auto;
    pointer-events: none;
    image-rendering: pixelated;
  }

  .flourish-left { left: 0; }
  .flourish-right { right: 0; transform: scaleX(-1); }

  .back-link {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    color: #2a2218;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid #7a6e52;
    border-radius: 4px;
    padding: 0.5rem 0.9rem;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    flex: 0 0 auto;
    z-index: 2;
  }

  .back-link:hover {
    color: #2a2218;
    background: rgba(255, 255, 255, 0.5);
  }

  .header-text {
    text-align: center;
    z-index: 1;
    flex: 1 1 auto;
    min-width: 0;
  }

  .page-title {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #2a2218;
    margin: 0;
  }

  .page-sub {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    color: #2a2218;
    margin: 0;
    line-height: 1.2;
  }

  .content {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .category-section {
    margin-bottom: 3rem;
  }

  .category-title {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 2rem;
    color: #2a2218;
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #8a7d60;
  }

  .section-note {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1rem;
    color: #3a3020;
    font-style: italic;
    margin: -0.75rem 0 1.25rem;
  }
  .font-link {
    color: #2a2218;
    text-decoration: underline;
    font-style: normal;
    margin-left: 0.3rem;
  }
  .font-link:hover {
    color: #000;
  }

  .characters {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    align-items: flex-start;
  }

  .character-card {
    background: #dbd0a0;
    border: 2px solid #7a6e52;
    border-radius: 4px;
    padding: 1.25rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2), 0 4px 8px rgba(0, 0, 0, 0.15);
    flex: 1;
    min-width: 280px;
    max-width: 560px;
  }

  .character-name {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
    color: #2a2218;
    margin: 0 0 0.75rem;
    text-transform: capitalize;
  }

  .sprite-showcase {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 4px;
    min-height: 140px;
  }

  .sprite-hero {
    height: 128px;
    width: auto;
    image-rendering: pixelated;
  }

  .sprite-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.75rem;
  }

  .sprite-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 3px;
    transition: background 0.2s;
    min-height: 100px;
  }

  .sprite-cell:hover {
    background: rgba(0, 0, 0, 0.08);
  }

  .sprite-gif {
    max-width: 96px;
    max-height: 96px;
    width: auto;
    height: auto;
    object-fit: contain;
    image-rendering: pixelated;
  }

  .sprite-label {
    display: block;
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.8rem;
    color: #3a3020;
    margin-top: 0.25rem;
    line-height: 1.2;
  }

  .characters-masonry {
    display: block;
    columns: 2;
    column-gap: 1.5rem;
  }

  .characters-masonry .character-card,
  .characters-masonry .locked-card {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    flex: none;
    min-width: unset;
    max-width: unset;
  }

  .locked-cell {
    opacity: 0.5;
    border: 1px dashed #8a7d60;
  }

  .locked-sprite-small {
    font-size: 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: grayscale(0.5);
  }

  /* Mystery / Hidden cards */
  .mystery-card {
    opacity: 0.7;
    border-style: dashed;
  }

  .mystery-sprite {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 4rem;
    color: #3a3020;
    height: 128px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mystery-text {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.95rem;
    color: #3a3020;
    text-align: center;
    margin: 0;
    font-style: italic;
  }

  /* Locked cards */
  .locked-card {
    opacity: 0.6;
    border-style: dashed;
  }

  .locked-sprite {
    font-size: 3rem;
    height: 128px;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: grayscale(0.5);
  }

  .locked-text {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.95rem;
    color: #3a3020;
    text-align: center;
    margin: 0;
    font-style: italic;
  }

  /* Gated character cards: show mystery placeholder, hide real sprites.
     When the auth script removes .gated, the real content reappears and
     the mystery placeholder hides. Name stays visible — only art is hidden. */
  .character-card.gated {
    border-style: dashed;
    position: relative;
  }
  .character-card.gated .real-content {
    display: none;
  }
  .gated-placeholder,
  .character-card .mystery-text {
    display: none;
  }
  .character-card.gated .gated-placeholder,
  .character-card.gated .mystery-text {
    display: flex;
  }
  .character-card.gated .mystery-text {
    text-align: center;
    justify-content: center;
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    color: #5a4d38;
    margin: 0;
  }
  .gate-badge {
    display: inline-block;
    margin-left: 0.6rem;
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: #5a4d38;
    background: rgba(58, 48, 32, 0.12);
    border: 1px solid rgba(58, 48, 32, 0.4);
    padding: 0.18rem 0.5rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    font-weight: 700;
    vertical-align: middle;
  }

  /* Gated individual sprite cells: hide real sprite, show locked placeholder.
     Same toggle pattern as character-level gating — removing .gated-cell
     hides the placeholder and shows the real content. */
  .sprite-cell.gated-cell .real-cell-content {
    display: none;
  }
  .cell-locked-placeholder {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    min-height: 80px;
  }
  .sprite-cell.gated-cell .cell-locked-placeholder {
    display: flex;
  }
  .cell-gate-badge {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: #5a4d38;
    background: rgba(58, 48, 32, 0.12);
    border: 1px solid rgba(58, 48, 32, 0.35);
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  /* Backgrounds */
  .bg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .bg-card {
    background: #dbd0a0;
    border: 2px solid #7a6e52;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2), 0 4px 8px rgba(0, 0, 0, 0.15);
  }

  .bg-label {
    display: block;
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1rem;
    color: #2a2218;
    padding: 0.75rem;
    text-align: center;
  }

  .locked-bg {
    font-size: 3rem;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: grayscale(0.5);
  }

  .page-footer {
    background: #cec08a;
    text-align: center;
    padding: 1.5rem 1rem;
  }

  @media (max-width: 768px) {
    .page-sub { display: none; }

    .page-title {
      font-size: 1.4rem;
    }

    .back-link {
      font-size: 1rem;
      padding: 0.4rem 0.7rem;
    }

    .character-card {
      min-width: 100%;
    }

    .characters-masonry {
