---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import AiDisclaimer from "../../components/AiDisclaimer.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("devlogs");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const devlogShortNames: Record<string, string> = {
  chronicles: "Chronicles of Nesis",
  "godot-and-claude": "Godot & Claude",
  studio: "AllByte Studios",
};
const backHref = `/devlog/${post.data.devlog}/`;
const categoryLabel = devlogShortNames[post.data.devlog] || "Devlog";

const breadcrumbs = [
  { href: "/", label: "Home" },
  { href: backHref, label: categoryLabel },
];
---

<BaseLayout title={`${post.data.title} — AllByte Studios`} description={post.data.description}>
  <PageHeader
    theme="engine"
    title={categoryLabel}
    backHref={backHref}
    backLabel={categoryLabel}
    breadcrumbs={breadcrumbs}
  >
    <AiDisclaimer />
  </PageHeader>
  <main class="article">
    <article class="content">
      <header class="article-header">
        <div class="post-meta">
          <span class={`category-tag ${post.data.category}`}>{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </div>
        <h2 class="post-title">{post.data.title}</h2>
        <p class="subtitle">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
      {headings.length > 0 && (
        <nav class="toc">
          <ul>
            {headings.filter((h) => h.depth <= 3).map((h) => (
              <li class={`toc-${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}
      <div class="post-content">
        <Content />
      </div>
    </article>
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style is:global>
  .article {
    background: #1a1e26;
    color: #e0e7ff;
    font-family: "Courier New", Courier, monospace;
    min-height: 100dvh;
    padding: 0 1rem 2rem;
  }

  .content {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.15);
    padding-bottom: 2rem;
    padding-top: 2rem;
  }

  .article-header .subtitle {
    font-size: 1.05rem;
    color: rgba(224, 231, 255, 0.6);
    line-height: 1.8;
    margin: 0 0 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .category-tag {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .category-tag.technical {
    background: rgba(167, 243, 208, 0.1);
    color: #a7f3d0;
  }

  .category-tag.creative {
    background: rgba(206, 192, 138, 0.15);
    color: #cec08a;
  }

  .post-meta time {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    color: rgba(224, 231, 255, 0.35);
  }

  .post-title {
    font-family: "Courier New", monospace;
    font-size: 1.6rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 0 0 0.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    color: rgba(167, 243, 208, 0.5);
    border: 1px solid rgba(167, 243, 208, 0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }

  .toc {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2rem;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #eaeaea;
  }

  .toc li.toc-3 {
    padding-left: 1.25rem;
  }

  .toc li::before {
    content: "—";
    color: rgba(167, 243, 208, 0.3);
    margin-right: 0.4rem;
  }

  .toc a {
    color: #a7f3d0;
    text-decoration: none;
  }

  .toc a:hover {
    text-decoration: underline;
  }

  .post-content {
    font-family: "Courier New", monospace;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #eaeaea;
  }

  .post-content h1, .post-content h2 {
    font-size: 1.4rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 2rem 0 0.75rem;
  }

  .post-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 1.5rem 0 0.5rem;
  }

  .post-content p {
    margin: 0 0 1rem;
  }

  .post-content ul {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
    list-style-type: disc;
  }

  .post-content ol {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
    list-style-type: decimal;
  }

  .post-content li {
    margin-bottom: 0.4rem;
  }

  .post-content strong {
    color: #e0e7ff;
  }

  .post-content code {
    background: rgba(167, 243, 208, 0.08);
    color: #a7f3d0;
    padding: 0.15rem 0.4rem;
    font-size: 0.85em;
    border-radius: 2px;
  }

  .post-content pre {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem;
    overflow-x: auto;
  }

  .post-content pre code {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #e0e7ff;
  }

  .post-content a {
    color: #a7f3d0;
  }

  .post-content a:hover {
    text-decoration: underline;
  }

  .post-content blockquote {
    border-left: 3px solid rgba(167, 243, 208, 0.3);
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    color: rgba(224, 231, 255, 0.7);
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.9rem;
  }

  .post-content th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid rgba(167, 243, 208, 0.2);
    color: #a7f3d0;
    font-weight: 600;
  }

  .post-content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.08);
    color: #eaeaea;
  }
</style>
