---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import AiDisclaimer from "../../components/AiDisclaimer.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  // All posts (including drafts) render in prod so admin can preview in place.
  // The post body is wrapped in .draft-post-content which CSS hides unless
  // body.is-admin is set by the client-side auth check in BaseLayout.
  const posts = await getCollection("devlogs");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const backHref = "/devlog/";
const categoryLabel = "Devlog";

const breadcrumbs = [
  { href: "/", label: "Home" },
  { href: backHref, label: categoryLabel },
];
---

<BaseLayout title={`${post.data.title} — AllByte Studios`} description={post.data.description}>
  <PageHeader
    theme="engine"
    title={post.data.title}
    backHref={backHref}
    backLabel={categoryLabel}
    breadcrumbs={breadcrumbs}
  >
    <AiDisclaimer />
  </PageHeader>
  <main class="article">
    {post.data.draft && (
      <div class="draft-banner">
        ⚠ DRAFT PREVIEW — visible to Hero+ subscribers. Text is still being revised and the published date will update on promotion.
      </div>
    )}
    {post.data.draft && (
      <div class="draft-gate">
        <h2>Draft post</h2>
        <p>This devlog entry is still in progress. Early access to drafts is a <strong>Hero</strong> tier perk.</p>
        <p><a href="/subscribe/">View subscription tiers →</a></p>
        <p><a href={backHref}>← Back to {categoryLabel}</a></p>
      </div>
    )}
    <article class:list={["content", post.data.draft && "draft-post-content"]}>
      <header class="article-header">
        <div class="post-meta">
          <span class={`category-tag ${post.data.category}`}>{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </div>
        <p class="subtitle">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
      {headings.length > 0 && (
        <nav class="toc">
          <ul>
            {headings.filter((h) => h.depth <= 3).map((h) => (
              <li class={`toc-${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}
      <div class="post-content">
        <Content />
      </div>
    </article>
  </main>
  <Footer theme="engine" />
  <script>
    // Render ```mermaid code blocks as SVG diagrams. Loaded on demand —
    // only runs when a devlog page actually has a .language-mermaid block.
    (async function renderMermaid() {
      // Astro/Shiki emits <pre data-language="mermaid"> (not <code class="language-mermaid">),
      // so match on the data-language attribute.
      const pres = document.querySelectorAll('pre[data-language="mermaid"]');
      if (!pres.length) return;
      const { default: mermaid } = await import(
        "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
      );
      mermaid.initialize({
        startOnLoad: false,
        theme: "dark",
        themeVariables: {
          primaryColor: "#12161c",
          primaryTextColor: "#e0e7ff",
          primaryBorderColor: "#a7f3d0",
          lineColor: "#a7f3d0",
          secondaryColor: "#1a1e26",
          tertiaryColor: "#22272e",
          fontFamily: "Courier New, monospace",
        },
        securityLevel: "loose",
      });
      let i = 0;
      for (const pre of pres) {
        // Shiki wraps each line in spans — textContent strips that back to raw source.
        const src = (pre.textContent || "").trim();
        const id = `mermaid-${++i}`;
        try {
          const { svg } = await mermaid.render(id, src);
          const wrap = document.createElement("div");
          wrap.className = "mermaid-diagram";
          wrap.innerHTML = svg;
          if (pre.parentElement) pre.parentElement.replaceChild(wrap, pre);
        } catch (err) {
          console.error("mermaid render failed:", err);
        }
      }
    })();
  </script>
</BaseLayout>

<style is:global>
  .article {
    background: #1a1e26;
    color: #e0e7ff;
    font-family: "Courier New", Courier, monospace;
    min-height: 100dvh;
    padding: 0 1rem 2rem;
  }

  .content {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.15);
    padding-bottom: 2rem;
    padding-top: 2rem;
  }

  .article-header .subtitle {
    font-size: 1.05rem;
    color: rgba(224, 231, 255, 0.6);
    line-height: 1.8;
    margin: 0 0 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .category-tag {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
  }

  .category-tag.engineering {
    background: rgba(167, 243, 208, 0.15);
    color: #a7f3d0;
  }
  .category-tag.workflow {
    background: rgba(167, 139, 250, 0.18);
    color: #c4b5fd;
  }
  .category-tag.strategy {
    background: rgba(96, 165, 250, 0.18);
    color: #93c5fd;
  }
  .category-tag.narrative {
    background: rgba(251, 191, 36, 0.18);
    color: #fcd34d;
  }
  .category-tag.craft {
    background: rgba(206, 192, 138, 0.2);
    color: #d4c595;
  }

  .post-meta time {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    color: rgba(224, 231, 255, 0.75);
  }

  .post-title {
    font-family: "Courier New", monospace;
    font-size: 1.6rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 0 0 0.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    color: rgba(167, 243, 208, 0.85);
    border: 1px solid rgba(167, 243, 208, 0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .toc {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2rem;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #eaeaea;
  }

  .toc li.toc-3 {
    padding-left: 1.25rem;
  }

  .toc li::before {
    content: "—";
    color: rgba(167, 243, 208, 0.65);
    margin-right: 0.4rem;
  }

  .toc a {
    color: #a7f3d0;
    text-decoration: none;
  }

  .toc a:hover {
    text-decoration: underline;
  }

  .post-content {
    font-family: "Courier New", monospace;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #eaeaea;
  }

  .post-content h1, .post-content h2 {
    font-size: 1.4rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 2rem 0 0.75rem;
  }

  .post-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 1.5rem 0 0.5rem;
  }

  .post-content p {
    margin: 0 0 1rem;
  }

  .post-content ul {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
    list-style-type: disc;
  }

  .post-content ol {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
    list-style-type: decimal;
  }

  .post-content li {
    margin-bottom: 0.4rem;
  }

  .post-content strong {
    color: #e0e7ff;
  }

  .post-content code {
    background: rgba(167, 243, 208, 0.08);
    color: #a7f3d0;
    padding: 0.15rem 0.4rem;
    font-size: 0.85em;
    border-radius: 2px;
  }

  .post-content pre {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem;
    overflow-x: auto;
  }

  .post-content pre code {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #e0e7ff;
  }

  .post-content a {
    color: #a7f3d0;
  }

  .post-content a:hover {
    text-decoration: underline;
  }

  .post-content blockquote {
    border-left: 3px solid rgba(167, 243, 208, 0.3);
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    color: rgba(224, 231, 255, 0.7);
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.9rem;
  }

  .post-content th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid rgba(167, 243, 208, 0.2);
    color: #a7f3d0;
    font-weight: 600;
  }

  .post-content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.08);
    color: #eaeaea;
  }

  .mermaid-diagram {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.15);
    border-radius: 4px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    text-align: center;
    overflow-x: auto;
  }
  .mermaid-diagram svg {
    max-width: 100%;
    height: auto;
    display: inline-block;
  }
</style>
