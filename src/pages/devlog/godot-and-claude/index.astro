---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/Footer.astro";
import AiDisclaimer from "../../../components/AiDisclaimer.astro";
import PageHeader from "../../../components/PageHeader.astro";
import "../../../styles/devlog.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("devlogs"))
  .filter((p) => p.data.devlog === "godot-and-claude")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Godot & Claude DevLog — AllByte Studios" description="Game development with Godot and Claude as an AI pair-programmer.">
  <PageHeader
    theme="engine"
    title="Godot & Claude Devlog"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[{ href: "/", label: "Home" }]}
  >
    <AiDisclaimer />
  </PageHeader>
  <main class="devlog-page">
    <div class="devlog-list">
    {posts.length > 0 ? posts.map((post) => (
      <a href={`/devlog/${post.id}/`} class="devlog-card">
        <div class="card-header">
          <span class={`category-tag ${post.data.category}`}>{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </time>
        </div>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    )) : <p class="empty-state">Posts coming soon.</p>}
    </div>
    <p class="more-coming">More posts coming soon.</p>
  </main>
  <Footer theme="engine" />
</BaseLayout>

