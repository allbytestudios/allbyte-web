---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import AiDisclaimer from "../../components/AiDisclaimer.astro";
import "../../styles/devlog.css";
import { getCollection } from "astro:content";

const allPosts = await getCollection("devlogs");
const counts = {
  chronicles: allPosts.filter((p) => p.data.devlog === "chronicles").length,
  "godot-and-claude": allPosts.filter((p) => p.data.devlog === "godot-and-claude").length,
  studio: allPosts.filter((p) => p.data.devlog === "studio").length,
};
---

<BaseLayout title="Devlog — AllByte Studios" description="Technical and creative devlogs from AllByte Studios.">
  <div class="page-header">
    <div class="header-title-row">
      <a href="/" class="back-link">&larr; Back</a>
      <h1 class="page-title">Devlog</h1>
    </div>
    <AiDisclaimer />
  </div>
  <main class="devlog-page">
    <div class="hub-cards">
      <a href="/devlog/chronicles/" class="hub-card">
        <h2>Chronicles of Nesis</h2>
        <p>Development of the tactical RPG.</p>
        <span class="entry-count">({counts.chronicles} {counts.chronicles === 1 ? "entry" : "entries"})</span>
      </a>
      <a href="/devlog/godot-and-claude/" class="hub-card">
        <h2>Godot & Claude</h2>
        <p>Game development with Godot and Claude as an AI pair-programmer.</p>
        <span class="entry-count">({counts["godot-and-claude"]} {counts["godot-and-claude"] === 1 ? "entry" : "entries"})</span>
      </a>
      <a href="/devlog/studio/" class="hub-card">
        <h2>AllByte Studios</h2>
        <p>Building the studio's web platform and infrastructure.</p>
        <span class="entry-count">({counts.studio} {counts.studio === 1 ? "entry" : "entries"})</span>
      </a>
    </div>
  </main>
  <Footer theme="engine" />
</BaseLayout>

