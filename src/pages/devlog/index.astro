---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Devlog — AllByte Studios" description="Technical and creative devlogs from AllByte Studios.">
  <div class="page-header">
    <div class="header-title-row">
      <a href="/" class="back-link">&larr; Back</a>
      <h1 class="page-title">Devlog</h1>
    </div>
  </div>
  <main class="devlog-page">
    <div class="devlog-list">
    {posts.map((post) => (
      <a href={`/devlog/${post.id}/`} class="devlog-card">
        <div class="card-header">
          <span class={`category-tag ${post.data.category}`}>{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </time>
        </div>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
    </div>
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style is:global>
  .page-header {
    background: #1a1e26;
    text-align: center;
    padding: 0.5rem 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .header-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .back-link {
    color: #a7f3d0;
    text-decoration: none;
    font-size: 1rem;
    font-family: "Courier New", monospace;
    background: rgba(167, 243, 208, 0.08);
    border: 1px solid rgba(167, 243, 208, 0.2);
    border-radius: 4px;
    padding: 0.2rem 0.75rem;
    transition: background 0.15s, border-color 0.15s;
    position: absolute;
    left: 1rem;
  }

  .back-link:hover {
    background: rgba(167, 243, 208, 0.15);
    border-color: rgba(167, 243, 208, 0.4);
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #a7f3d0;
    margin: 0;
    font-family: "Courier New", monospace;
    padding-left: 6rem;
    padding-right: 6rem;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1rem;
    }
  }

  .devlog-page {
    background: #1a1e26;
    min-height: 100dvh;
    padding: 0 1rem 2rem;
  }

  .devlog-list {
    max-width: 760px;
    margin: 0 auto;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .devlog-card {
    display: block;
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .devlog-card:hover {
    border-color: rgba(167, 243, 208, 0.3);
    background: #161c24;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .category-tag {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .category-tag.technical {
    background: rgba(167, 243, 208, 0.1);
    color: #a7f3d0;
  }

  .category-tag.creative {
    background: rgba(206, 192, 138, 0.15);
    color: #cec08a;
  }

  .card-header time {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    color: rgba(224, 231, 255, 0.35);
  }

  .devlog-card h2 {
    font-family: "Courier New", monospace;
    font-size: 1.15rem;
    font-weight: 600;
    color: #e0e7ff;
    margin: 0 0 0.4rem;
  }

  .devlog-card p {
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    color: rgba(224, 231, 255, 0.6);
    line-height: 1.6;
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    color: rgba(167, 243, 208, 0.5);
    border: 1px solid rgba(167, 243, 208, 0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }
</style>
