---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Footer from "../../components/Footer.astro";
import LegendSquareApp from "../../components/LegendSquareApp.svelte";
---

<BaseLayout
  title="Legend's Square — AllByte Studios"
  description="A private space for Legend tier subscribers to talk directly with AllByte."
>
  <PageHeader
    theme="engine"
    title="Legend's Square"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[{ href: "/", label: "Home" }]}
  />
  <main class="legend-page">
    <LegendSquareApp client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .legend-page {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
  }
</style>
