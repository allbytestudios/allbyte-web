---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import assetIndex from "../data/asset-index.json";

const title = "Music — AllByte Studios";
const description = "Original compositions for The Chronicles of Nesis, handcrafted by AllByte.";

// Tracks gated behind the Initiate tier (and above). Server-side tagged so
// the markup ships locked by default; client-side script unlocks after the
// auth check passes. Names match asset-index.json `name` field exactly.
const GATED_TRACKS = new Set([
  "DwarvenRuins",
  "ImpendingConclusion",
  "Sleep",
  "Victory",
]);

// Clean up track names for display
function formatTrackName(name: string): string {
  return name
    .replace(/([A-Z])/g, " $1")
    .replace(/(\d+)/g, " $1")
    .replace(/_/g, " ")
    .replace(/^rest zapsplat.*/, "Rest Theme")
    .trim();
}
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <header class="page-header">
      <img src="/Flourish.png" alt="" class="flourish flourish-left" />
      <img src="/Flourish.png" alt="" class="flourish flourish-right" />
      <a href="/" class="back-link">&larr; Back</a>
      <div class="header-text">
        <h1 class="page-title">Music</h1>
        <p class="page-sub">Original compositions for The Chronicles of Nesis</p>
      </div>
      <div class="header-spacer" aria-hidden="true"></div>
    </header>

    <main class="content">
      <div class="track-list">
        {assetIndex.music.map((track, i) => {
          const gated = GATED_TRACKS.has(track.name);
          return (
            <button
              class={`track-card track-btn${gated ? " gated" : ""}`}
              data-index={i}
              data-gated={gated ? "true" : "false"}
              data-required-tier={gated ? "initiate" : ""}
            >
              <div class="track-info">
                <span class="track-number">{String(i + 1).padStart(2, "0")}</span>
                <span class="track-name">{formatTrackName(track.name)}</span>
                {gated && (
                  <span class="gate-badge">&#128274; Initiate+</span>
                )}
              </div>
              <span class="play-hint"><span class="hint-play">&#9654; Play</span><span class="hint-active">&#9654; Now Playing</span></span>
            </button>
          );
        })}

        <!-- Locked tracks -->
        <div class="track-card locked-card">
          <div class="track-info">
            <span class="track-number">??</span>
            <span class="track-name locked-name">&#128274; More tracks coming soon</span>
          </div>
        </div>
      </div>
    </main>

    <Footer theme="heart" />
  </div>
  <script>
    import assetIndex from "../data/asset-index.json";

    const API = "https://wj3xkrm1r1.execute-api.us-east-1.amazonaws.com";
    const TIER_RANK = { default: 0, initiate: 1, hero: 2, legend: 3, admin: 4 };
    function tierAtLeast(userTier: string | null | undefined, required: string): boolean {
      const u = TIER_RANK[(userTier ?? "default") as keyof typeof TIER_RANK] ?? 0;
      const r = TIER_RANK[required as keyof typeof TIER_RANK] ?? 0;
      return u >= r;
    }

    const trackButtons = document.querySelectorAll<HTMLButtonElement>(".track-btn");

    // Load all tracks into the global player on first click
    let loaded = false;
    function ensureLoaded(index: number) {
      if (!loaded) {
        window.dispatchEvent(new CustomEvent("music-player:load", {
          detail: { tracks: assetIndex.music, index }
        }));
        loaded = true;
      } else {
        window.dispatchEvent(new CustomEvent("music-player:play", {
          detail: { index }
        }));
      }
    }

    function highlightActive(index: number) {
      trackButtons.forEach(btn => {
        btn.classList.toggle("active", Number(btn.dataset.index) === index);
      });
    }

    function showGateMessage(requiredTier: string) {
      const msg = `This track is part of the ${requiredTier[0].toUpperCase() + requiredTier.slice(1)} tier or above.\n\nSubscribe to unlock it.`;
      window.alert(msg);
    }

    trackButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        if (btn.classList.contains("gated")) {
          showGateMessage(btn.dataset.requiredTier || "initiate");
          return;
        }
        const index = Number(btn.dataset.index);
        ensureLoaded(index);
        highlightActive(index);
      });
    });

    // Unlock gated tracks if the signed-in user has the required tier.
    async function checkTierAndUnlock() {
      const token = localStorage.getItem("allbyte_token");
      if (!token) return; // signed out — keep locked
      try {
        const res = await fetch(`${API}/auth/me`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) return;
        const data = await res.json();
        const tier = data?.user?.tier ?? "default";
        document.querySelectorAll<HTMLButtonElement>(".track-btn.gated").forEach(btn => {
          const required = btn.dataset.requiredTier || "initiate";
          if (tierAtLeast(tier, required)) {
            btn.classList.remove("gated");
            const badge = btn.querySelector(".gate-badge");
            if (badge) badge.remove();
          }
        });
      } catch {
        // Network error — fail closed (stay locked)
      }
    }
    checkTierAndUnlock();

    // Sync highlight when player changes track (e.g. next/prev from mini player)
    window.addEventListener("music-player:track-changed", ((e: CustomEvent) => {
      highlightActive(e.detail.index);
    }) as EventListener);

    // Highlight on load if player is already playing
    if (window.__musicPlayerPlaying && window.__musicPlayerIndex != null) {
      highlightActive(window.__musicPlayerIndex);
    }
  </script>
</BaseLayout>

<style is:global>
  .page {
    min-height: 100dvh;
    background: #ddd5b8;
    display: flex;
    flex-direction: column;
  }

  .page-header {
    background: #cec08a;
    padding: 0.4rem 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    overflow: clip;
    min-height: 56px;
  }

  .flourish {
    position: absolute;
    top: 0;
    height: 100%;
    width: auto;
    pointer-events: none;
    image-rendering: pixelated;
  }

  .flourish-left { left: 0; }
  .flourish-right { right: 0; transform: scaleX(-1); }

  .back-link {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    color: #2a2218;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid #7a6e52;
    border-radius: 4px;
    padding: 0.5rem 0.9rem;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    flex: 0 0 auto;
    z-index: 2;
  }

  .back-link:hover {
    color: #2a2218;
    background: rgba(255, 255, 255, 0.5);
  }

  .header-text {
    text-align: center;
    z-index: 1;
    flex: 1 1 auto;
    min-width: 0;
  }

  .page-title {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #2a2218;
    margin: 0;
  }

  .page-sub {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    color: #2a2218;
    margin: 0;
    line-height: 1.2;
  }

  .content {
    flex: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .track-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .track-card {
    background: #dbd0a0;
    border: 2px solid #7a6e52;
    border-radius: 4px;
    padding: 1rem 1.25rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2), 0 4px 8px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .track-info {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex: 1;
    min-width: 180px;
  }

  .track-number {
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    color: #3a3020;
    flex-shrink: 0;
  }

  .track-name {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.25rem;
    color: #2a2218;
  }

  .track-btn {
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    width: 100%;
    text-align: left;
    font: inherit;
  }

  .track-btn:hover {
    background: #cec08a;
    border-color: #5a4d38;
  }

  .track-btn.active {
    background: #cec08a;
    border-color: #5a4d38;
    box-shadow: inset 3px 0 0 #5a4d38;
  }

  .track-btn.active .play-hint {
    opacity: 1;
  }

  .hint-active {
    display: none;
  }

  .track-btn.active .hint-play {
    display: none;
  }

  .track-btn.active .hint-active {
    display: inline;
  }

  .play-hint {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    color: #3a3020;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .track-btn:hover .play-hint {
    opacity: 1;
  }

  .locked-card {
    opacity: 0.6;
    border-style: dashed;
  }

  .locked-name {
    color: #3a3020;
    font-style: italic;
  }

  .track-btn.gated {
    background: #c5b67e;
    border-style: dashed;
    cursor: not-allowed;
  }
  .track-btn.gated:hover {
    background: #b8a872;
  }
  .track-btn.gated .track-name {
    color: #5a4d38;
    font-style: italic;
  }
  .gate-badge {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: #5a4d38;
    background: rgba(58, 48, 32, 0.12);
    border: 1px solid rgba(58, 48, 32, 0.35);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    margin-left: 0.6rem;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .page-footer {
    background: #cec08a;
    text-align: center;
    padding: 1.5rem 1rem;
  }

  @media (max-width: 768px) {
    .flourish {
      width: 4rem;
    }

    .page-sub { display: none; }

    .page-title {
      font-size: 1.4rem;
    }

    .back-link {
      font-size: 1rem;
      padding: 0.4rem 0.7rem;
    }

    .track-card {
      padding: 0.6rem 0.9rem;
      gap: 0.5rem;
    }

    .track-name {
      font-size: 1.1rem;
    }

    .play-hint {
      display: none;
    }
  }

  .header-spacer {
    flex: 0 0 auto;
    width: 44px;
  }
</style>
