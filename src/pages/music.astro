---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import assetIndex from "../data/asset-index.json";

const title = "Music — AllByte Studios";
const description = "Original compositions for The Chronicles of Nesis, handcrafted by AllByte.";

// Clean up track names for display
function formatTrackName(name: string): string {
  return name
    .replace(/([A-Z])/g, " $1")
    .replace(/(\d+)/g, " $1")
    .replace(/_/g, " ")
    .replace(/^rest zapsplat.*/, "Rest Theme")
    .trim();
}
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <header class="page-header">
      <img src="/Flourish.png" alt="" class="flourish flourish-left" />
      <img src="/Flourish.png" alt="" class="flourish flourish-right" />
      <a href="/" class="back-link">&larr; Back</a>
      <div class="header-text">
        <h1 class="page-title">Music</h1>
        <p class="page-sub">Original compositions for The Chronicles of Nesis</p>
      </div>
    </header>

    <main class="content">
      <div class="track-list">
        {assetIndex.music.map((track, i) => (
          <button class="track-card track-btn" data-index={i}>
            <div class="track-info">
              <span class="track-number">{String(i + 1).padStart(2, "0")}</span>
              <span class="track-name">{formatTrackName(track.name)}</span>
            </div>
            <span class="play-hint"><span class="hint-play">&#9654; Play</span><span class="hint-active">&#9654; Now Playing</span></span>
          </button>
        ))}

        <!-- Locked tracks -->
        <div class="track-card locked-card">
          <div class="track-info">
            <span class="track-number">??</span>
            <span class="track-name locked-name">&#128274; More tracks coming soon</span>
          </div>
        </div>
      </div>
    </main>

    <Footer theme="heart" />
  </div>
  <script>
    import assetIndex from "../data/asset-index.json";

    const trackButtons = document.querySelectorAll<HTMLButtonElement>(".track-btn");

    // Load all tracks into the global player on first click
    let loaded = false;
    function ensureLoaded(index: number) {
      if (!loaded) {
        window.dispatchEvent(new CustomEvent("music-player:load", {
          detail: { tracks: assetIndex.music, index }
        }));
        loaded = true;
      } else {
        window.dispatchEvent(new CustomEvent("music-player:play", {
          detail: { index }
        }));
      }
    }

    function highlightActive(index: number) {
      trackButtons.forEach(btn => {
        btn.classList.toggle("active", Number(btn.dataset.index) === index);
      });
    }

    trackButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const index = Number(btn.dataset.index);
        ensureLoaded(index);
        highlightActive(index);
      });
    });

    // Sync highlight when player changes track (e.g. next/prev from mini player)
    window.addEventListener("music-player:track-changed", ((e: CustomEvent) => {
      highlightActive(e.detail.index);
    }) as EventListener);

    // Highlight on load if player is already playing
    if (window.__musicPlayerPlaying && window.__musicPlayerIndex != null) {
      highlightActive(window.__musicPlayerIndex);
    }
  </script>
</BaseLayout>

<style is:global>
  .page {
    min-height: 100dvh;
    background: #ddd5b8;
    display: flex;
    flex-direction: column;
  }

  .page-header {
    background: #cec08a;
    padding: 0.4rem 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: clip;
  }

  .flourish {
    position: absolute;
    top: 0;
    height: 100%;
    width: auto;
    pointer-events: none;
    image-rendering: pixelated;
  }

  .flourish-left { left: 0; }
  .flourish-right { right: 0; transform: scaleX(-1); }

  .back-link {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    color: #2a2218;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid #7a6e52;
    border-radius: 4px;
    padding: 0.5rem 0.9rem;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    position: absolute;
    left: 3.5rem;
    z-index: 2;
  }

  .back-link:hover {
    color: #2a2218;
    background: rgba(255, 255, 255, 0.5);
  }

  .header-text {
    text-align: center;
    z-index: 1;
    padding-left: 6rem;
    padding-right: 6rem;
  }

  .page-title {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #2a2218;
    margin: 0;
  }

  .page-sub {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    color: #2a2218;
    margin: 0;
    line-height: 1.2;
  }

  .content {
    flex: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .track-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .track-card {
    background: #dbd0a0;
    border: 2px solid #7a6e52;
    border-radius: 4px;
    padding: 1rem 1.25rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2), 0 4px 8px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .track-info {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex: 1;
    min-width: 180px;
  }

  .track-number {
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    color: #8a7a58;
    flex-shrink: 0;
  }

  .track-name {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.25rem;
    color: #2a2218;
  }

  .track-btn {
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    width: 100%;
    text-align: left;
    font: inherit;
  }

  .track-btn:hover {
    background: #cec08a;
    border-color: #5a4d38;
  }

  .track-btn.active {
    background: #cec08a;
    border-color: #5a4d38;
    box-shadow: inset 3px 0 0 #5a4d38;
  }

  .track-btn.active .play-hint {
    opacity: 1;
  }

  .hint-active {
    display: none;
  }

  .track-btn.active .hint-play {
    display: none;
  }

  .track-btn.active .hint-active {
    display: inline;
  }

  .play-hint {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 0.9rem;
    color: #5a4d38;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .track-btn:hover .play-hint {
    opacity: 1;
  }

  .locked-card {
    opacity: 0.6;
    border-style: dashed;
  }

  .locked-name {
    color: #8a7a58;
    font-style: italic;
  }

  .page-footer {
    background: #cec08a;
    text-align: center;
    padding: 1.5rem 1rem;
  }

  @media (max-width: 768px) {
    .flourish {
      width: 6rem;
    }

    .page-sub { display: none; }

    .page-title {
      font-size: 1.4rem;
    }

    .header-text {
      padding-left: 4rem;
      padding-right: 4rem;
    }

    .back-link {
      font-size: 1rem;
      left: 1rem;
      padding: 0.4rem 0.7rem;
    }

    .track-card {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
