  }

  .content {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.15);
    padding-bottom: 2rem;
  }

  .article-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #a7f3d0;
    margin: 0 0 0.75rem;
  }

  .article-header .subtitle {
    font-family: "AllByteCustom", Georgia, "Times New Roman", serif;
    font-size: 1.15rem;
    color: rgba(224, 231, 255, 0.6);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .article-header .reference {
    font-size: 0.95rem;
    color: #eaeaea;
    margin: 0 0 0.75rem;
  }

  .article-header .reference a {
    color: #a7f3d0;
  }

  .article-header time {
    font-size: 0.85rem;
    color: rgba(224, 231, 255, 0.35);
  }

  /* Table of Contents */
  .toc {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2rem;
  }

  .toc ol {
    padding-left: 1.25rem;
    margin: 0;
  }

  .toc ul {
    padding-left: 1.25rem;
    margin: 0;
    list-style: none;
  }

  .toc > ol > li {
    margin-bottom: 0.15rem;
  }

  .toc li {
    font-size: 0.9rem;
    line-height: 1.4;
    color: #eaeaea;
    margin-bottom: 0.1rem;
  }

  .toc ul li::before {
    content: "—";
    color: rgba(167, 243, 208, 0.3);
    margin-right: 0.4rem;
  }

  .toc a {
    color: #a7f3d0;
    text-decoration: none;
  }

  .toc a:hover {
    text-decoration: underline;
  }

  .content section {
    margin-bottom: 2.5rem;
  }

  .content h2 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 0 0 1rem;
  }

  .content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #a7f3d0;
    margin: 2rem 0 0.75rem;
    padding-top: 0.5rem;
  }

  .content p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #eaeaea;
    margin: 0 0 1rem;
  }

  .content strong {
    color: #e0e7ff;
  }

  .content code {
    background: rgba(167, 243, 208, 0.08);
    color: #a7f3d0;
    padding: 0.15rem 0.4rem;
    font-size: 0.85em;
    border-radius: 2px;
  }

  .content a {
    color: #a7f3d0;
  }

  .content a:hover {
    text-decoration: underline;
  }

  .content ul, .content ol {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }

  .content li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #eaeaea;
    margin-bottom: 0.4rem;
  }

  /* Tables */
