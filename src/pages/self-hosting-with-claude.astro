    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem;
    overflow-x: auto;
  }

  .code-block pre {
    margin: 0;
  }

  .code-block code {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #e0e7ff;
  }

  /* Lessons */
  .lessons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lesson {
    background: #12161c;
    border: 1px solid rgba(167, 243, 208, 0.12);
    border-radius: 4px;
    padding: 1rem 1.25rem;
  }

  .lesson h3 {
    margin: 0 0 0.5rem;
  }

  .lesson p {
    margin: 0;
  }

</style>
