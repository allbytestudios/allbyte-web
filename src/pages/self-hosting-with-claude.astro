    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.9rem;
  }

  .content th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid rgba(167, 243, 208, 0.2);
    color: #a7f3d0;
    font-weight: 600;
  }

  .content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(167, 243, 208, 0.08);
    color: #eaeaea;
    font-size: 0.95rem;
  }

