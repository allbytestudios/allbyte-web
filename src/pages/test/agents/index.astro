---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/Footer.astro";
import AgentsApp from "../../../components/AgentsApp.svelte";
import TestNav from "../../../components/TestNav.svelte";
---

<BaseLayout
  title="Agent Status — AllByte Studios"
  description="Live status of expert and worker agents building The Chronicles of Nesis."
>
  <main class="agents-shell">
    <TestNav active="agents" client:load />
    <AgentsApp client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .agents-shell {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
  }
</style>
