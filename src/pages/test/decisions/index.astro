---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Footer from "../../../components/Footer.astro";
import DecisionQueue from "../../../components/DecisionQueue.svelte";
import TestNav from "../../../components/TestNav.svelte";
---

<BaseLayout
  title="Decisions — Dev Console — AllByte Studios"
  description="Pending owner decisions from Arc's agent team."
>
  <PageHeader
    theme="engine"
    title="Dev Console"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[{ href: "/", label: "Home" }]}
  />
  <main class="decisions-shell">
    <TestNav active="decisions" client:load />
    <DecisionQueue client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .decisions-shell {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
  }
</style>
