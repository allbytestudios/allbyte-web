---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Footer from "../../../components/Footer.astro";
import TestDashboardApp from "../../../components/TestDashboardApp.svelte";
import TestNav from "../../../components/TestNav.svelte";
---

<BaseLayout
  title="Tests — Dev Console — AllByte Studios"
  description="Live test results across three runner tiers for Chronicles of Nesis."
>
  <PageHeader
    theme="engine"
    title="Dev Console"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[{ href: "/", label: "Home" }]}
  />
  <main class="test-page">
    <TestNav active="tests" client:load />
    <TestDashboardApp client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .test-page {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
    padding: 0.5rem 0 2rem;
  }
</style>
