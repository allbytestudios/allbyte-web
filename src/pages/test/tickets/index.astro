---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Footer from "../../../components/Footer.astro";
import TicketsApp from "../../../components/TicketsApp.svelte";
import TestNav from "../../../components/TestNav.svelte";
---

<BaseLayout
  title="Tickets — Dev Console — AllByte Studios"
  description="Bug tracker and feature board for The Chronicles of Nesis web demo."
>
  <PageHeader
    theme="engine"
    title="Dev Console"
    backHref="/"
    backLabel="Home"
    breadcrumbs={[{ href: "/", label: "Home" }]}
  />
  <main class="tickets-shell">
    <TestNav active="tickets" client:load />
    <TicketsApp client:only="svelte" />
  </main>
  <Footer theme="engine" />
</BaseLayout>

<style>
  .tickets-shell {
    background: #0a0e17;
    min-height: calc(100vh - 160px);
  }
</style>
